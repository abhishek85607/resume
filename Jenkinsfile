pipeline{
  agent any 
  stages{
    stage('Introduction'){
      steps{
        echo "Hello Abhishek !"
      }
    }
    stage('study check'){
      steps{
        echo " How is your studing is going ::"
      }
    }
    stage('system check'){
      steps{
        sh "uptime"
      }
    }
    stage ('information'){
      steps {
        echo " (sh) is used to execuate linux commands " 
      }
    }
  }
}
